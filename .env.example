# ─────────────────────────────────────────────────────────
#  Engrama — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit the real .env file.
# ─────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── OpenAI ───────────────────────────────────────────────
# Get your API key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4-turbo
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── Supabase (PostgreSQL) ─────────────────────────────────
# Create a free project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_or_service_role_key

# ── Qdrant (Vector DB) ───────────────────────────────────
# When using Docker Compose this is pre-configured for you
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=engrama_memories

# ── Authentication ───────────────────────────────────────
# Generate a strong random string: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret_min_32_chars
API_KEY=replace_with_your_api_key

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ── Memory Defaults ──────────────────────────────────────
DEFAULT_MEMORY_TTL_DAYS=365
MAX_MEMORIES_PER_USER=100000
EMBEDDING_DIMENSION=3072

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
